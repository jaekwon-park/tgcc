[Unit]
Description=tgcc — Telegram-Claude Code Bridge
Documentation=https://github.com/jaekwon-park/tgcc
After=network.target

[Service]
Type=simple
User=insainty
WorkingDirectory=/home/insainty
EnvironmentFile=/opt/tgcc/bin/.env
# Place the tmux control socket outside PrivateTmp so spawned tmux/claude
# sessions survive a tgcc restart (KillMode=process) and the freshly started
# tgcc can re-attach to them. A dedicated dir (not /tmp) also keeps tgcc's tmux
# server isolated from the user's own tmux sessions.
Environment=TMUX_TMPDIR=/opt/tgcc/run
ExecStart=/opt/tgcc/bin/tgcc serve
Restart=always
RestartSec=5

# Graceful shutdown. KillMode=process so only the bot process is signalled on
# stop/restart — tmux and its child claude sessions keep running and are
# reconciled (re-attached) by the new tgcc instance instead of being SIGKILLed.
KillMode=process
KillSignal=SIGTERM
TimeoutStopSec=10

# Security hardening
# Note: ProtectHome is intentionally NOT set. Claude Code (spawned per session)
# needs to write to several paths under $HOME beyond ~/.claude — notably ~/.local/
# (Claude version cache), ~/.cache, and Node's npm/npx temp dirs. Enabling
# ProtectHome=read-only + an explicit ReadWritePaths list caused Claude's TUI to
# silently fail to render (process running, pane blank, no transcript ever
# written). ProtectSystem=strict + NoNewPrivileges + PrivateTmp still constrain
# the bot itself; tighten ProtectHome again only after auditing every path Claude
# Code touches at startup and per-spawn.
NoNewPrivileges=yes
PrivateTmp=yes
ProtectSystem=strict
ReadWritePaths=/opt/tgcc/bin /opt/tgcc/run /home/insainty/projects /home/insainty/.claude /home/insainty/.claude.json

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=tgcc

[Install]
WantedBy=default.target
